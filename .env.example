# Telegram settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DRY_RUN=true

# Runtime settings
DATABASE_PATH=internships.db
LOG_LEVEL=INFO

# Collector toggles
ENABLE_STATIC_EXAMPLE=true
ENABLE_GREENHOUSE=true
ENABLE_LEVER=true

# Collector source values (comma-separated)
STATIC_SOURCE_URLS=
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANY_SLUGS=

# Filtering rules (comma-separated)
FILTER_INCLUDE_KEYWORDS=ai,machine learning,deep learning,computer vision,multimodal,video generation,research internship
FILTER_EXCLUDE_KEYWORDS=senior,staff,principal,phd required
FILTER_PREFERRED_LOCATIONS=remote,europe,germany,switzerland,netherlands,eu

# Scoring weights
SCORE_INCLUDE_KEYWORD_WEIGHT=2.0
SCORE_PREFERRED_LOCATION_BONUS=1.5
SCORE_REMOTE_BONUS=1.0
SCORE_RESEARCH_BONUS=1.0
